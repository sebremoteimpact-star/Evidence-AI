# ─────────────────────────────────────────────
# Evidence AI — Variables del Backend
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# Base de datos (postgres+asyncpg)
DATABASE_URL=postgresql+asyncpg://evidence:cambiar_en_local@localhost:5432/evidence_ai

# Redis (cache + cola arq + SSE pubsub)
REDIS_URL=redis://localhost:6379/0

# IA — Claude
ANTHROPIC_API_KEY=
CLAUDE_REASONING_MODEL=claude-sonnet-4-6
CLAUDE_FAST_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=4096

# Búsqueda
SEARCH_PROVIDERS=duckduckgo,brave,google_cse  # orden de prioridad; usa los que tengan key
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Auth
JWT_SECRET=cambiar_a_random_seguro_minimo_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate limits (formato slowapi)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_VERIFICATION=10/hour

# Límites del pipeline de verificación
MAX_CLAIMS_PER_VERIFICATION=15
MAX_SOURCES_PER_CLAIM=12
MAX_INPUT_CHARS=50000
VERIFICATION_TIMEOUT_SECONDS=180

# Almacenamiento de archivos (local en dev)
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=500

# Observabilidad (opcional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=evidence-ai-api
