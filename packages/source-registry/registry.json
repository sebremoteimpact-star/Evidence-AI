  "blocked_as_primary": [
    "facebook.com", "instagram.com", "tiktok.com", "x.com", "twitter.com",
    "reddit.com", "youtube.com", "medium.com", "substack.com",
    "wordpress.com", "blogspot.com", "tumblr.com"
