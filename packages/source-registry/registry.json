    "verificat.cat":            { "tier": 4, "type": "factcheck" },

    "mit.edu":                  { "tier": 5, "type": "university" },
    "harvard.edu":              { "tier": 5, "type": "university" },
    "stanford.edu":             { "tier": 5, "type": "university" },
    "ox.ac.uk":                 { "tier": 5, "type": "university" },
    "cam.ac.uk":                { "tier": 5, "type": "university" },
    "pewresearch.org":          { "tier": 5, "type": "research_institute" },
    "brookings.edu":            { "tier": 5, "type": "think_tank" },
    "rand.org":                 { "tier": 5, "type": "think_tank" },

    "reuters.com":              { "tier": 6, "type": "news_agency" },
    "apnews.com":               { "tier": 6, "type": "news_agency" },
    "afp.com":                  { "tier": 6, "type": "news_agency" },
    "bbc.com":                  { "tier": 6, "type": "news" },
    "bbc.co.uk":                { "tier": 6, "type": "news" },
    "elpais.com":               { "tier": 6, "type": "news" },
    "elmundo.es":               { "tier": 6, "type": "news" },
    "lemonde.fr":               { "tier": 6, "type": "news" },
    "nytimes.com":              { "tier": 6, "type": "news" },
    "washingtonpost.com":       { "tier": 6, "type": "news" },
    "theguardian.com":          { "tier": 6, "type": "news" },
    "ft.com":                   { "tier": 6, "type": "news" },
    "economist.com":            { "tier": 6, "type": "news" }
