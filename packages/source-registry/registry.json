    "fullfact.org":             { "tier": 4, "type": "factcheck" },
    "snopes.com":               { "tier": 4, "type": "factcheck" },
    "maldita.es":               { "tier": 4, "type": "factcheck" },
    "newtral.es":               { "tier": 4, "type": "factcheck" },
    "colombiacheck.com":        { "tier": 4, "type": "factcheck" },
    "factual.afp.com":          { "tier": 4, "type": "factcheck" },
