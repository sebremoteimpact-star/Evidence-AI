{
  "$schema": "./schema.json",
  "version": 1,
  "description": "Mapeo de dominios a tier de fuente. Compartido entre backend (ranking) y frontend (badges).",
  "tiers": {
    "1": {
      "name": "Peer-reviewed / Académico primario",
      "description": "Investigación científica revisada por pares con metodología pública",
      "color": "#10b981"
    },
    "2": {
      "name": "Documento oficial primario",
      "description": "Documentos emitidos por gobiernos, cortes, organismos electorales, oficinas estadísticas nacionales, bancos centrales",
      "color": "#3b82f6"
    },
    "3": {
      "name": "Organismos internacionales",
      "description": "Organizaciones internacionales con metodología transparente",
      "color": "#6366f1"
    },
    "4": {
      "name": "Fact-checking",
      "description": "Organizaciones de fact-checking con metodología pública (IFCN)",
      "color": "#8b5cf6"
    },
    "5": {
      "name": "Academia / Think tanks",
      "description": "Universidades, institutos de investigación, think tanks con financiación transparente",
      "color": "#a855f7"
    },
    "6": {
      "name": "Periodismo profesional",
      "description": "Medios de comunicación profesionales — usar solo cuando no hay evidencia primaria",
      "color": "#94a3b8"
    }
  },
  "domains": {
    "pubmed.ncbi.nlm.nih.gov":  { "tier": 1, "type": "academic_database" },
    "ncbi.nlm.nih.gov":         { "tier": 1, "type": "academic_database" },
    "scholar.google.com":       { "tier": 1, "type": "academic_index" },
    "semanticscholar.org":      { "tier": 1, "type": "academic_index" },
    "api.semanticscholar.org":  { "tier": 1, "type": "academic_api" },
    "doaj.org":                 { "tier": 1, "type": "academic_index" },
    "openalex.org":             { "tier": 1, "type": "academic_index" },
    "api.openalex.org":         { "tier": 1, "type": "academic_api" },
    "crossref.org":             { "tier": 1, "type": "academic_metadata" },
    "api.crossref.org":         { "tier": 1, "type": "academic_api" },
    "arxiv.org":                { "tier": 1, "type": "preprint", "notes": "Preprint — no peer-reviewed" },
    "ssrn.com":                 { "tier": 1, "type": "preprint", "notes": "Preprint — no peer-reviewed" },
    "nature.com":               { "tier": 1, "type": "journal" },
    "science.org":              { "tier": 1, "type": "journal" },
    "nejm.org":                 { "tier": 1, "type": "journal" },
    "thelancet.com":            { "tier": 1, "type": "journal" },
    "bmj.com":                  { "tier": 1, "type": "journal" },
    "cell.com":                 { "tier": 1, "type": "journal" },
    "plos.org":                 { "tier": 1, "type": "journal" },

    "supremecourt.gov":         { "tier": 2, "type": "court" },
    "congress.gov":             { "tier": 2, "type": "legislature" },
    "europarl.europa.eu":       { "tier": 2, "type": "legislature" },
    "ec.europa.eu":             { "tier": 2, "type": "government" },
    "data.europa.eu":           { "tier": 2, "type": "open_data" },
    "data.gov":                 { "tier": 2, "type": "open_data" },
    "datos.gob.es":             { "tier": 2, "type": "open_data" },
    "ine.es":                   { "tier": 2, "type": "national_statistics" },
    "bls.gov":                  { "tier": 2, "type": "national_statistics" },
