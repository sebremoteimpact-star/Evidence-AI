    "bde.es":                   { "tier": 2, "type": "central_bank" },

    "who.int":                  { "tier": 3, "type": "international_org" },
    "un.org":                   { "tier": 3, "type": "international_org" },
    "data.un.org":              { "tier": 3, "type": "international_org" },
    "oecd.org":                 { "tier": 3, "type": "international_org" },
    "data.oecd.org":            { "tier": 3, "type": "international_org" },
    "worldbank.org":            { "tier": 3, "type": "international_org" },
    "data.worldbank.org":       { "tier": 3, "type": "international_org" },
    "imf.org":                  { "tier": 3, "type": "international_org" },
