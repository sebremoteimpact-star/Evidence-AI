# Forzar line endings consistentes (LF) en todo el repo
# excepto scripts que requieren CRLF en Windows
* text=auto eol=lf

# Scripts Windows
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binarios — no normalizar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.mp4 binary
*.webm binary
*.woff binary
*.woff2 binary
