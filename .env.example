# ─────────────────────────────────────────────
# Evidence AI — Variables de entorno raíz
# ─────────────────────────────────────────────
# Este archivo es el TEMPLATE. Copia a .env y completa los valores reales.
# .env está en .gitignore — nunca lo subas al repo.

# Entorno (development | test | production)
NODE_ENV=development
ENVIRONMENT=development

# ─────────────────────────────────────────────
# Servicios de datos (compartidos por API y worker)
# ─────────────────────────────────────────────
POSTGRES_USER=evidence
POSTGRES_PASSWORD=cambiar_en_local
POSTGRES_DB=evidence_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────────
# IA — Claude API (obligatorio)
# ─────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Búsqueda — DuckDuckGo es default (sin key).
# Otras son opcionales: si están presentes el sistema las usará como fallback.
# ─────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ─────────────────────────────────────────────
# Autenticación
# ─────────────────────────────────────────────
# Genera con: openssl rand -base64 32
JWT_SECRET=cambiar_a_random_seguro

# OAuth Google (opcional — si se omite, solo email/password funciona)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────
# URLs públicas
# ─────────────────────────────────────────────
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Observabilidad (opcional)
# ─────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
